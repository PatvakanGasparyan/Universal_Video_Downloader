# Application
DEBUG=false
SECRET_KEY=change-me-in-production
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Downloads
DOWNLOADS_DIR=./backend/downloads
TEMP_DIR=./backend/downloads/temp
MAX_CONCURRENT_DOWNLOADS=3

# FFmpeg (leave empty to use system PATH)
FFMPEG_LOCATION=

# YouTube / site authentication — Netscape cookies.txt from your browser
# Place your exported file at: ./config/cookies.txt
COOKIES_FILE=./config/cookies.txt

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Optional Redis queue
REDIS_URL=

# Rate limiting
RATE_LIMIT=30/minute

# Metadata cache TTL (seconds)
METADATA_CACHE_TTL=3600
