# Application
DEBUG=false
SECRET_KEY=change-me-in-production
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Downloads
DOWNLOADS_DIR=./backend/downloads
TEMP_DIR=./backend/downloads/temp
MAX_CONCURRENT_DOWNLOADS=3

# FFmpeg (leave empty to use system PATH)
FFMPEG_LOCATION=

# YouTube / site authentication — Netscape cookies.txt from your browser
# Place your exported file at: ./data/cookies.txt
COOKIES_FILE=./data/cookies.txt

# Authentication fallback pipeline
# When a site blocks anonymous access, try cookies straight from a locally
# installed browser before falling back to cookies.txt.
# IMPORTANT: set to false on headless servers (Docker / EC2 / k8s) — there is no
# browser there and enabling it just wastes time on every request.
COOKIES_FROM_BROWSER=true
COOKIE_BROWSER_ORDER=["chrome","chromium","edge","firefox"]

# yt-dlp reliability tuning
YTDLP_SOCKET_TIMEOUT=30
YTDLP_RETRIES=3
EXTRACT_TIMEOUT=90
TRANSIENT_RETRY_ATTEMPTS=2

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Optional Redis queue
REDIS_URL=

# Rate limiting
RATE_LIMIT=30/minute

# Metadata cache TTL (seconds)
METADATA_CACHE_TTL=3600

# AWS S3 storage (set S3_ENABLED=true in production)
S3_ENABLED=false
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PREFIX=downloads
S3_DELETE_LOCAL_AFTER_UPLOAD=true
