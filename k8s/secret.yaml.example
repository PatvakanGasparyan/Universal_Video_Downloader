# Copy this file to secret.yaml, fill in real values, then apply:
#   cp k8s/secret.yaml.example k8s/secret.yaml
#   kubectl apply -f k8s/secret.yaml
#
# Never commit secret.yaml to git.
#
# On EC2 with an IAM instance profile (from Terraform), you can leave AWS keys
# empty and boto3 will use the node's IAM role — but only if pod metadata access
# works on your cluster. When in doubt, create an IAM user key pair for the app.
apiVersion: v1
kind: Secret
metadata:
  name: uvd-secrets
  namespace: universal-video-downloader
  labels:
    app.kubernetes.io/name: universal-video-downloader
    app.kubernetes.io/component: backend
type: Opaque
stringData:
  # Required — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
  SECRET_KEY: "change-me-in-production"

  # AWS credentials (optional when the EC2 IAM role is available to pods)
  AWS_ACCESS_KEY_ID: ""
  AWS_SECRET_ACCESS_KEY: ""
